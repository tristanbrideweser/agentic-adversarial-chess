# =============================================================================
# Stockfish engine parameters
# Loaded by docker-compose.yaml for both white and black service instances.
# Per-player overrides are set directly in the compose service definitions.
# =============================================================================

# UCI engine search depth (higher = stronger, slower)
STOCKFISH_DEPTH=15

# Time limit per move in seconds (used if depth limit isn't hit first)
STOCKFISH_TIME_LIMIT=2.0

# Optional ELO rating cap (uncomment to limit playing strength)
# STOCKFISH_ELO=1500

# CPU threads allocated to the engine process
STOCKFISH_THREADS=2

# Hash table size in MB (transposition table)
STOCKFISH_HASH_MB=256

# ROS 2 domain ID (must match all other nodes)
ROS_DOMAIN_ID=42

# RMW implementation
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp