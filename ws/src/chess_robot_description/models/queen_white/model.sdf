            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.92 0.90 0.85 1</ambient>
          <diffuse>0.92 0.90 0.85 1</diffuse>
        </material>
      </visual>

      <!-- "Q" imprint: rectangular outline + diagonal tail at bottom-right. -->
      <visual name="letter_top">
        <pose>0 0.009 0.0205 0 0 0</pose>
        <geometry><box><size>0.012 0.002 0.001</size></box></geometry>
        <material>
          <ambient>0.10 0.08 0.06 1</ambient>
          <diffuse>0.10 0.08 0.06 1</diffuse>
        </material>
      </visual>
      <visual name="letter_bottom">
        <pose>0 -0.009 0.0205 0 0 0</pose>
        <geometry><box><size>0.012 0.002 0.001</size></box></geometry>
        <material>
          <ambient>0.10 0.08 0.06 1</ambient>
          <diffuse>0.10 0.08 0.06 1</diffuse>
        </material>
      </visual>
      <visual name="letter_left">
        <pose>-0.005 0 0.0205 0 0 0</pose>
        <geometry><box><size>0.002 0.020 0.001</size></box></geometry>
        <material>
          <ambient>0.10 0.08 0.06 1</ambient>
          <diffuse>0.10 0.08 0.06 1</diffuse>
        </material>
      </visual>
      <visual name="letter_right">
        <pose>0.005 0 0.0205 0 0 0</pose>
        <geometry><box><size>0.002 0.020 0.001</size></box></geometry>
        <material>
          <ambient>0.10 0.08 0.06 1</ambient>
