<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="queen_white">
    <static>false</static>
    <pose>0 0 0 0 0 0</pose>

    <link name="link">

      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00002</ixx>
          <iyy>0.00002</iyy>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.015</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.8</mu>
              <mu2>1.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
