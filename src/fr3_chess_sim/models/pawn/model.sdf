<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="pawn">
    <static>false</static>
    <pose>0 0 0 0 0 0</pose>

    <link name="link">

      <!-- Physics -->
      <inertial>
        <mass>0.05</mass>   <!-- 50 grams -->
        <inertia>
          <ixx>0.00002</ixx>
          <iyy>0.00002</iyy>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <!-- Collision (simple cylinder = stable) -->
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.015</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.8</mu>
              <mu2>1.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <!-- Visual -->
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.015</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>

    </link>
  </model>
</sdf>