<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="chess_world">
    <gravity>0 0 -9.81</gravity>

    <!-- Conservative physics for stability -->
    <physics name="physics" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.95 0.95 0.95 1</background>
    </scene>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <direction>-0.2 0.1 -1</direction>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
    </light>

    <!-- Ground -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
        </visual>
      </link>
    </model>

    <!-- Table: 1.2 x 0.8 x 0.75 -->
    <model name="table">
      <static>true</static>
      <pose>0 0 0.375 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.2 0.8 0.75</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.2</mu><mu2>1.2</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
            <material>
                <ambient>0.8 0.8 0.8 1</ambient>
                <diffuse>0.8 0.8 0.8 1</diffuse>
                <specular>0.1 0.1 0.1 1</specular>
            </material>
          <geometry><box><size>1.2 0.8 0.75</size></box></geometry>
        </visual>
      </link>
    </model>

    <!-- Chessboard: 0.45 x 0.45 x 0.03, on top of table -->
    <model name="chessboard">
      <static>true</static>
      <pose>0 0 0.765 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.45 0.45 0.03</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.5</mu><mu2>1.5</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.45 0.45 0.03</size></box></geometry>
        </visual>
      </link>
    </model>


<model name="overhead_rgbd_camera">
  <static>true</static>
  <pose>0 0 1.2 0 1.5708 0</pose> <!-- x y z roll pitch yaw; pitch=90deg downward -->
  <link name="link">
    <sensor name="rgb_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>5.0</far>
        </clip>
      </camera>
      <topic>/rgbd/rgb/image</topic>
    </sensor>

    <sensor name="depth_camera" type="depth_camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>5.0</far>
        </clip>
      </camera>
      <topic>/rgbd/depth/image</topic>
    </sensor>
  </link>
</model>

  </world>
</sdf>