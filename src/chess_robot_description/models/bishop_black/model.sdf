<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="bishop_black">
    <static>false</static>
    <pose>0 0 0 0 0 0</pose>

    <link name="link">

      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00002</ixx>
          <iyy>0.00002</iyy>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.015</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.8</mu>
              <mu2>1.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.015</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>

      <!-- "B" imprint: stem + two stacked loops. -->
      <visual name="letter_stem">
        <pose>-0.004 0 0.0205 0 0 0</pose>
        <geometry><box><size>0.002 0.020 0.001</size></box></geometry>
        <material>
          <ambient>0.95 0.95 0.95 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
        </material>
      </visual>
      <visual name="letter_top">
        <pose>0 0.009 0.0205 0 0 0</pose>
        <geometry><box><size>0.010 0.002 0.001</size></box></geometry>
        <material>
          <ambient>0.95 0.95 0.95 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
        </material>
      </visual>
      <visual name="letter_middle">
        <pose>0 0 0.0205 0 0 0</pose>
        <geometry><box><size>0.010 0.002 0.001</size></box></geometry>
        <material>
          <ambient>0.95 0.95 0.95 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
        </material>
      </visual>
      <visual name="letter_bottom">
        <pose>0 -0.009 0.0205 0 0 0</pose>
        <geometry><box><size>0.010 0.002 0.001</size></box></geometry>
        <material>
          <ambient>0.95 0.95 0.95 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
        </material>
      </visual>
      <visual name="letter_loop_top_right">
        <pose>0.004 0.0045 0.0205 0 0 0</pose>
        <geometry><box><size>0.002 0.009 0.001</size></box></geometry>
        <material>
          <ambient>0.95 0.95 0.95 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
        </material>
      </visual>
      <visual name="letter_loop_bottom_right">
        <pose>0.004 -0.0045 0.0205 0 0 0</pose>
        <geometry><box><size>0.002 0.009 0.001</size></box></geometry>
        <material>
          <ambient>0.95 0.95 0.95 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
