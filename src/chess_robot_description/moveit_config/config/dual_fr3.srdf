<?xml version="1.0" ?>
<robot name="dual_fr3">

  <group name="white_arm">
    <chain base_link="white_fr3_link0" tip_link="white_fr3_hand_tcp"/>
  </group>

  <group name="black_arm">
    <chain base_link="black_fr3_link0" tip_link="black_fr3_hand_tcp"/>
  </group>

  <group name="white_hand">
    <joint name="white_fr3_finger_joint1"/>
  </group>

  <group name="black_hand">
    <joint name="black_fr3_finger_joint1"/>
  </group>

  <end_effector name="white_hand" parent_link="white_fr3_hand_tcp" group="white_hand" parent_group="white_arm"/>
  <end_effector name="black_hand" parent_link="black_fr3_hand_tcp" group="black_hand" parent_group="black_arm"/>

  <group_state name="ready" group="white_arm">
    <joint name="white_fr3_joint1" value="0"/>
    <joint name="white_fr3_joint2" value="-0.3"/>
    <joint name="white_fr3_joint3" value="0"/>
    <joint name="white_fr3_joint4" value="-2.5"/>
    <joint name="white_fr3_joint5" value="0"/>
    <joint name="white_fr3_joint6" value="2.2"/>
    <joint name="white_fr3_joint7" value="0.785"/>
  </group_state>

  <group_state name="ready" group="black_arm">
    <joint name="black_fr3_joint1" value="0"/>
    <joint name="black_fr3_joint2" value="-0.3"/>
    <joint name="black_fr3_joint3" value="0"/>
    <joint name="black_fr3_joint4" value="-2.5"/>
    <joint name="black_fr3_joint5" value="0"/>
    <joint name="black_fr3_joint6" value="2.2"/>
    <joint name="black_fr3_joint7" value="0.785"/>
  </group_state>

  <disable_collisions link1="white_fr3_link0" link2="black_fr3_link0" reason="Never"/>
  <disable_collisions link1="white_fr3_link0" link2="white_fr3_link1" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_link1" link2="white_fr3_link2" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_link2" link2="white_fr3_link3" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_link3" link2="white_fr3_link4" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_link4" link2="white_fr3_link5" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_link5" link2="white_fr3_link6" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_link6" link2="white_fr3_link7" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_link7" link2="white_fr3_hand" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_hand" link2="white_fr3_leftfinger" reason="Adjacent"/>
  <disable_collisions link1="white_fr3_hand" link2="white_fr3_rightfinger" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link0" link2="black_fr3_link1" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link1" link2="black_fr3_link2" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link2" link2="black_fr3_link3" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link3" link2="black_fr3_link4" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link4" link2="black_fr3_link5" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link5" link2="black_fr3_link6" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link6" link2="black_fr3_link7" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_link7" link2="black_fr3_hand" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_hand" link2="black_fr3_leftfinger" reason="Adjacent"/>
  <disable_collisions link1="black_fr3_hand" link2="black_fr3_rightfinger" reason="Adjacent"/>

</robot>
