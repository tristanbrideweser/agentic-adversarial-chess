<model name="overhead_rgbd_camera">
  <static>true</static>
  <pose>0 0 1.2 0 1.5708 0</pose> <!-- x y z roll pitch yaw; pitch=90deg downward -->
  <link name="link">
    <sensor name="rgb_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.5</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>5.0</far>
        </clip>
      </camera>
      <topic>/overhead_camera/image</topic>
    </sensor>

    <sensor name="depth_camera" type="depth_camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.5</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>5.0</far>
        </clip>
      </camera>
      <topic>/overhead_camera/depth</topic>
    </sensor>
  </link>
</model>

  </world>
</sdf>
