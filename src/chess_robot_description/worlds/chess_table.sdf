<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="chess_world">
    <gravity>0 0 -9.81</gravity>

    <!-- Required system plugins. Fortress auto-loads a few, but Physics,
         SceneBroadcaster, UserCommands, and Sensors must be declared
         explicitly for sensors (cameras) and `ros_gz_sim create` to work. -->
    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- Conservative physics for stability -->
    <physics name="physics" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.95 0.95 0.95 1</background>
    </scene>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <direction>-0.2 0.1 -1</direction>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
    </light>

    <!-- Ground -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
        </visual>
      </link>
    </model>

    <!-- Table: 1.2 x 0.8 x 0.75 -->
    <model name="table">
      <static>true</static>
      <pose>0 0 0.375 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.2 0.8 0.75</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.2</mu><mu2>1.2</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
            <material>
                <ambient>0.8 0.8 0.8 1</ambient>
                <diffuse>0.8 0.8 0.8 1</diffuse>
                <specular>0.1 0.1 0.1 1</specular>
            </material>
          <geometry><box><size>1.2 0.8 0.75</size></box></geometry>
        </visual>
      </link>
    </model>

    <!-- Chessboard: 0.45 x 0.45 x 0.03, on top of table -->
    <model name="chessboard">
